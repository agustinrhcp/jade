#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require 'result'
require 'jade'

module ColoredStrings
  RBG_COLORS = {
    green: '90;237;115',
    violet: '203;91;207',
    red: '232;35;41',
    orange: '214;126;49',
  }.freeze

  refine String do
    RBG_COLORS.each do |name, rgb|
      define_method(name) do
        "\e[38;2;#{rgb}m#{self}\e[0m"
      end
    end
  end
end

module PrettyPrinting
  refine Jade::AST::Node do
    def inspect
      Jade::AST::PrettyPrinter.print(self)
    end
  end
end

module Jade
  module REPL
    extend self

    using ColoredStrings
    using PrettyPrinting

    def run
      puts "Jade REPL — type :quit to exit\n\n"

      registry = nil
      current_entry = nil
      scope = nil
      env = nil
      var_gen = Frontend::TypeChecking::VarGen.new

      @ruby_env = binding

      loop do
        print "> "
        line = $stdin.gets
        break unless line
        input = line.strip

        case input
        when ":quit", ":q", ":exit"
          puts "Bye!"
          break
        when ""
          next
        end

        case evaluate(input, registry, current_entry, scope, env, var_gen)
        in Err(message)
          puts message
        in Ok([registry, current_entry, scope, env, type, generated_code])
          puts generated_code.violet

          eval(generated_code, @ruby_env)
            .then { puts "=> #{it.inspect.green} : #{type.to_s.violet}"}
        end
      end
    end

    private

    def evaluate(src, registry, current_entry, scope, env, var_gen)
      Source.new(nil, src)
        .then { Lexer.tokenize(it) }
        .then { Parser.parse(it) }
        .on_err { return Err[it.message] } => Ok(ast)

      Frontend::FixityFixer.fix(ast)
        # .then { puts it.inspect.orange }

      Frontend
        .run_repl(ast, registry, current_entry, scope, env, var_gen)
        .on_err { return Err[it.first.message] } => Ok([
          ast, type, registry, current_entry, scope, env,
        ])

      Ok[[
        registry,
        current_entry,
        scope,
        env,
        type,
        Codegen.generate(ast, registry),
      ]]
    end
  end
end

# TODO: Allow multiline
# Allow debug options.
# Show errors nicely

Jade::REPL.run

