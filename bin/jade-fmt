#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require 'jade/result'
require 'jade/source'
require 'jade/lexer'
require 'jade/ast'
require 'jade/parsing'
require 'jade/formatter'
require 'jade/frontend/comment_attacher'

def usage
  $stderr.puts <<~USAGE
    Usage: jade-fmt [options] [file]

    Options:
      -i, --in-place   Rewrite the file in place.
      -c, --check      Exit 0 if formatted, 1 if drift, 2 on parse error.
                       Does not write.
      -h, --help       Show this message.

    Reads from stdin when no file is given.
  USAGE
  exit 1
end

mode    = :stdout
file    = nil

ARGV.each do |arg|
  case arg
  when '-i', '--in-place' then mode = :in_place
  when '-c', '--check'    then mode = :check
  when '-h', '--help'     then usage
  when /\A-/              then $stderr.puts("unknown option: #{arg}"); usage
  else
    usage if file
    file = arg
  end
end

source_text =
  if file
    File.read(file)
  elsif !$stdin.tty?
    $stdin.read
  else
    usage
  end

source = Jade::Source.new(uri: file || 'stdin', text: source_text)
tokens = Jade::Lexer.tokenize(source)

case Jade::Parsing.parse(tokens, entry: source.uri)
in Jade::Ok([ast, comments])
  formatted = Jade::Formatter.format(ast, comments:, source:) + "\n"

  case mode
  when :in_place
    usage unless file
    if formatted == source_text
      exit 0
    else
      File.write(file, formatted)
      $stderr.puts "Formatted #{file}"
    end

  when :check
    if formatted == source_text
      exit 0
    else
      $stderr.puts "#{file || 'stdin'}: not formatted"
      exit 1
    end

  when :stdout
    print formatted
  end

in Jade::Err(error)
  $stderr.puts "Parse error: #{error.message}"
  exit 2
end
