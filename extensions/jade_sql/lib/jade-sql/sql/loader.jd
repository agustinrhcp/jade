module Sql.Loader exposing (
  group_by,
  lookup_or_empty,
)

import Dict exposing (Dict)


def group_by(items: List(a), key: a -> k) -> Dict(k, List(a))
  List.fold(
    items,
    Dict.empty,
    (acc, item) -> {
      k = key(item)

      case Dict.get(acc, k)
      of Just(existing) -> Dict.insert(acc, k, existing ++ [item])
      of Nothing -> Dict.insert(acc, k, [item])
    },
  )


def lookup_or_empty(grouped: Dict(k, List(a)), key: k) -> List(a)
  case Dict.get(grouped, key)
  of Just(items) -> items
  of Nothing -> []
