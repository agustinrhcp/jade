module BasicsExamples exposing (add, greet, absolute, clamp)

def add(a: Int, b: Int) -> Int
  a + b
end

def greet(name: String) -> String
  "Hello, " ++ name ++ "!"
end

def absolute(n: Int) -> Int
  case n < 0
  of True then 0 - n
  of False then n
  end
end

def clamp(value: Int, min: Int, max: Int) -> Int
  case value < min
  of True then min
  of False then
    case value > max
    of True then max
    of False then value
    end
  end
end
